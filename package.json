{
  "name": "taskvista",
  "version": "1.0.0",
  "private": true,
  "description": "TaskVista - タスク管理 Web アプリケーション",
  "scripts": {
    "deploy": "node scripts/deploy.mjs",
    "deploy:backend": "node scripts/deploy.mjs --backend",
    "deploy:frontend": "node scripts/deploy.mjs --frontend",
    "deploy:bootstrap": "node scripts/deploy.mjs --bootstrap",
    "deploy:dry-run": "node scripts/deploy.mjs --dry-run",
    "local:build": "node scripts/local-build.mjs",
    "local:api": "node scripts/local-api.mjs",
    "local:sam": "node scripts/local-sam.mjs",
    "cdk": "npm --prefix infra run cdk --",
    "cdk:synth": "npm --prefix infra run synth --",
    "cdk:deploy:dev": "npm --prefix infra run deploy:dev",
    "cdk:deploy:prod": "npm --prefix infra run deploy:prod"
  }
}