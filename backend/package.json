{
  "name": "taskvista-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "node -e \"import('fs').then(fs=>fs.rmSync('dist',{recursive:true,force:true}))\"",
    "local:build": "tsc",
    "local:api": "node ../scripts/local-api.mjs",
    "local:sam": "node ../scripts/local-sam.mjs",
    "deploy": "node ../scripts/deploy.mjs --backend",
    "deploy:backend": "node ../scripts/deploy.mjs --backend"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1083.0",
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "uuid": "^9.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147",
    "@types/node": "^22.13.10",
    "@types/uuid": "^9.0.8",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
